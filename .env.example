# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
# Full Postgres connection string.
# On Vercel: add a Postgres integration or supply your own.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─────────────────────────────────────────────
# Supabase (Auth + Image Storage)
# ─────────────────────────────────────────────
# Your Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — used by the API server for admin operations (bypasses RLS).
# Keep this SECRET — never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anon / public key — safe to expose; used as fallback for read-only routes.
SUPABASE_ANON_KEY=eyJ...

# ─────────────────────────────────────────────
# Session / Security
# ─────────────────────────────────────────────
# A long random string used to sign session tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# ─────────────────────────────────────────────
# Runtime (set automatically by hosting platforms)
# ─────────────────────────────────────────────
# Port the API server listens on. Vercel / Replit set this automatically.
PORT=8080

# Node.js environment.  Set to "production" on all hosted environments.
NODE_ENV=production
